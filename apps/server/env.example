# ── База данных ───────────────────────────────────────────────
# Вариант 1 (рекомендуется на Render): строка подключения целиком.
# Render «Add from Database» добавляет именно её. Если задана — DB_* ниже игнорируются.
DATABASE_URL=
# Вариант 2 (локально / Docker): раздельные параметры (используются, если нет DATABASE_URL).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=smart_wallet_tracker

# ── Сервер ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# Разрешённые origin'ы клиента (через запятую). Прод: https://<client>.vercel.app
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# ── Telegram-бот (Этап 4) ─────────────────────────────────────
# Токен от @BotFather. Если пусто — бот не запускается.
# Также используется для валидации Telegram initData в prod (NODE_ENV=production).
TELEGRAM_BOT_TOKEN=

# ── LLM для парсинга сообщений бота ───────────────────────────
# Провайдер: anthropic (по умолчанию) | groq. Бот стартует только если у выбранного провайдера задан ключ.
LLM_PROVIDER=anthropic

# Claude API. Ключ формата sk-ant-api03-... из console.anthropic.com.
ANTHROPIC_API_KEY=
# Модель парсинга (необязательно; по умолчанию claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5

# Groq — бесплатная альтернатива (OpenAI-совместимый). Ключ gsk_... с console.groq.com.
# Активируется при LLM_PROVIDER=groq.
GROQ_API_KEY=
# Модель Groq (необязательно; по умолчанию llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
