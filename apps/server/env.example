# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=smart_wallet_tracker

# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# Telegram (валидация initData в prod; в dev можно оставить пустым — будет dev-обход)
# Также используется ботом (Этап 4). Если пусто — бот не запускается.
TELEGRAM_BOT_TOKEN=

# Claude API — парсинг текстовых сообщений бота (Этап 4)
# Если ключ не задан — бот не запускается.
ANTHROPIC_API_KEY=
# Модель парсинга (необязательно; по умолчанию claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5

